{
  "manifest_version": 3,
  "name": "Before You Send",
  "version": "1.0.0",
  "description": "Gut-check your emails with AI before sending. Flags tone issues, missing context, and regrettable phrasing.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://mail.google.com/*"],
  "background": {
    "service_worker": "background/index.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/index.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Before You Send"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/*.css"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
